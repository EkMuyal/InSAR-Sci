*.coh
*.disp
*.rslc
*.slc
*.rmli
*.lt
*.hgt
*.off
*.par
*.tops_par

# ============================================================
# Data policy
# Keep real data out of Git. Small sample CSVs can be added
# deliberately later if we decide they are safe and useful.
# ============================================================
data/
